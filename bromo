#!/usr/bin/env bash
# ------------------------------------------------------------------
# bromo launcher (POSIX).
# Wraps `java -jar target/bromo.jar --stdio` with the JVM flags the
# server expects:
#  --enable-preview  StructuredTaskScope / ScopedValue (Java 25 preview)
#  -XX:+UseZGC       Generational ZGC (default flavour in 25)
#  -XX:AOTMode=auto  JEP 514 one-step AOT: cache produced on first run,
#                    consumed on every subsequent run.
#  -XX:AOTCache=…    Cache path. Lives under target/ so `mvn clean`
#                    drops it.
# ------------------------------------------------------------------
set -e
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
JAR="$SCRIPT_DIR/target/bromo.jar"
AOT_CACHE="$SCRIPT_DIR/target/bromo.aot"

if [ -z "${JAVA_HOME:-}" ]; then
    if [ -d "$HOME/.jdks/temurin-25.0.3" ]; then
        export JAVA_HOME="$HOME/.jdks/temurin-25.0.3"
    elif ! command -v java >/dev/null 2>&1; then
        echo "Error: JAVA_HOME not set and no java on PATH." >&2
        exit 1
    fi
fi

if [ ! -f "$JAR" ]; then
    echo "Error: $JAR not found. Build it first:" >&2
    echo "  ./mvnw -DskipTests package" >&2
    exit 1
fi

JAVA_BIN="${JAVA_HOME:+$JAVA_HOME/bin/}java"
exec "$JAVA_BIN" \
    --enable-preview \
    -XX:+UseZGC \
    -XX:AOTMode=auto \
    -XX:AOTCache="$AOT_CACHE" \
    -jar "$JAR" "$@"
